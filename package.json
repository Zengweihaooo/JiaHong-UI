{
  "name": "@jiahong/ui",
  "version": "0.1.0",
  "description": "Shared Vue 3 UI component library for JiaHong medical products.",
  "type": "module",
  "private": false,
  "main": "./dist/jiahong-ui.cjs",
  "module": "./dist/jiahong-ui.js",
  "exports": {
    ".": {
      "import": "./dist/jiahong-ui.js",
      "require": "./dist/jiahong-ui.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./fonts.css": "./styles/fonts.css",
    "./assets/*": "./assets/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "styles/fonts.css",
    "assets",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css",
    "**/*.vue"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:pages": "vite build --config vite.docs.config.js && cp -R assets/. dist-pages/assets/",
    "preview": "vite preview --host 0.0.0.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.3.5",
    "vue": "^3.5.16"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
